#!/usr/bin/env python3
"""
Compare closed pull-requests of a GitHub repo with the PR numbers that appear
in its ``doc/changes.rst`` file.

Features added
--------------
* ``--after N`` - only list PRs whose number is greater than *N*.
* ``--verbose`` - emit reStructuredText blocks ready to be pasted into
    ``changes.rst``.  Each block contains a bullet with the PR title and the
    reference link.

Usage
-----
        python compare_closed_prs.py REPO_URL [--token TOKEN] [--after N]
                                              [--verbose] [--output FILE]

* ``REPO_URL`` - e.g. ``https://github.com/desihub/desispec``.
* ``--token`` - optional personal-access token (avoids rate-limit).
* ``--after`` - only show PRs with a number > N.
* ``--verbose`` - produce RST entries instead of a plain number list.
* ``--output`` - write the result to a file; otherwise prints to stdout.
* ``--debug`` - start IPython prompt at end instead of exiting

Written by LBL CBorg Coder AI with prompts from Stephen Bailey
"""

import argparse
import re
import sys
import urllib.parse
from pathlib import Path
from typing import Set, List
from datetime import datetime, timezone
from zoneinfo import ZoneInfo  # Requires Python 3.9+

import requests

# ----------------------------------------------------------------------
# Constants / helpers
# ----------------------------------------------------------------------
GITHUB_API = "https://api.github.com"
RAW_CONTENT = "https://raw.githubusercontent.com"
PER_PAGE = 100  # max permitted by GitHub


def _github_get(url: str,
                token: str | None = None,
                params: dict | None = None) -> requests.Response:
    """GET request with optional auth and basic error handling."""
    headers = {"Accept": "application/vnd.github+json"}
    if token:
        headers["Authorization"] = f"token {token}"
    resp = requests.get(url, headers=headers, params=params, timeout=30)
    if resp.status_code == 403 and resp.headers.get("X-RateLimit-Remaining") == "0":
        raise RuntimeError("GitHub rate limit exceeded – supply a personal access token.")
    resp.raise_for_status()
    return resp


def parse_repo_url(url: str) -> tuple[str, str]:
    """Extract (owner, repo) from ``https://github.com/owner/repo``."""
    p = urllib.parse.urlparse(url)
    if p.scheme not in ("http", "https"):
        raise ValueError("Repository URL must start with http:// or https://")
    parts = p.path.strip("/").split("/")
    if len(parts) < 2:
        raise ValueError("URL must contain owner and repo, e.g. https://github.com/owner/repo")
    owner, repo = parts[0], parts[1].removesuffix(".git")
    return owner, repo


def get_merged_prs(owner: str,
                   repo: str,
                   token: str | None = None) -> dict[int, datetime]:
    """
    Return a mapping {pr_number: merged_at_datetime} for every PR that was
    merged (i.e. closed by merge).
    """
    prs: dict[int, datetime] = {}
    page = 1
    while True:
        url = f"{GITHUB_API}/repos/{owner}/{repo}/pulls"
        params = {"state": "closed", "per_page": PER_PAGE, "page": page}
        data = _github_get(url, token=token, params=params).json()
        if not data:
            break

        for pr in data:
            # ``merged_at`` is null for non-merged closed PRs.
            merged_at = pr.get("merged_at")
            if merged_at:
                # GitHub timestamps are ISO-8601 UTC strings
                merged_dt = datetime.fromisoformat(merged_at.rstrip("Z")).replace(tzinfo=timezone.utc)
                prs[pr["number"]] = merged_dt
        page += 1
    return prs


def fetch_changes_rst(owner: str, repo: str, token: str | None = None) -> str:
    """Download ``doc/changes.rst`` from the ``main`` branch (raw content)."""
    raw_url = f"{RAW_CONTENT}/{owner}/{repo}/main/doc/changes.rst"
    return _github_get(raw_url, token=token).text


def _get_tag_commit_date(owner: str, repo: str, tag_sha: str,
                         token: str | None = None) -> datetime:
    """
    Return the datetime of the commit that a tag points to.
    Works for both annotated and lightweight tags.
    """
    # First try to treat the SHA as an *annotated* tag object.
    tag_url = f"{GITHUB_API}/repos/{owner}/{repo}/git/tags/{tag_sha}"
    try:
        tag_obj = _github_get(tag_url, token=token).json()
        # Annotated tags have a ``tagger`` field with a ``date``.
        date_str = tag_obj.get("tagger", {}).get("date")
        if date_str:
            return datetime.fromisoformat(date_str.rstrip("Z")).replace(tzinfo=timezone.utc)
    except requests.HTTPError:
        # If the request fails we fall back to treating it as a lightweight tag.
        pass

    # Lightweight tag – fetch the commit it points to.
    commit_url = f"{GITHUB_API}/repos/{owner}/{repo}/commits/{tag_sha}"
    commit_obj = _github_get(commit_url, token=token).json()
    date_str = commit_obj["commit"]["committer"]["date"]
    return datetime.fromisoformat(date_str.rstrip("Z")).replace(tzinfo=timezone.utc)


def get_tags_with_dates(owner: str,
                        repo: str,
                        token: str | None = None) -> list[tuple[str, datetime]]:
    """
    Return a list ``[(tag_name, tag_date), ...]`` sorted by ``tag_date`` (oldest -> newest).
    """
    tags: list[tuple[str, datetime]] = []
    page = 1
    while True:
        url = f"{GITHUB_API}/repos/{owner}/{repo}/tags"
        params = {"per_page": PER_PAGE, "page": page}
        data = _github_get(url, token=token, params=params).json()
        if not data:
            break

        for tag in data:
            name = tag["name"]
            sha = tag["commit"]["sha"]
            tag_date = _get_tag_commit_date(owner, repo, sha, token=token)
            tags.append((name, tag_date))
        page += 1

    tags.sort(key=lambda t: t[1])          # chronological order
    return tags


def group_prs_by_next_tag(prs: dict[int, datetime],
                          tags: list[tuple[str, datetime]]) -> dict[str, list[int]]:
    """
    For each PR, find the first tag whose date is later than the PR's merge date.
    Returns a mapping ``{tag_name: [pr_numbers...]}``.  PRs that have no later tag
    are grouped under the special key ``'NO_TAG'``.
    """
    grouped: dict[str, list[int]] = {}
    for pr_num, merged_dt in prs.items():
        tag_name = "NO_TAG"
        for name, tag_dt in tags:
            if tag_dt > merged_dt:
                tag_name = name
                break
        grouped.setdefault(tag_name, []).append(pr_num)
    return grouped


# ----------------------------------------------------------------------
# Parsing ``changes.rst`` for tag numbers; supports either
# .. _`PR #864`: https://github.com/desihub/desitarget/pull/864
# .. _`#225`: https://github.com/desihub/desiutil/pull/225
# ----------------------------------------------------------------------

_LINE_RE = re.compile(
    r"""^\s*\.\.\s+_`[^`]+`:\s+https?://github\.com/"""
    r"""(?P<owner>[^/]+)/(?P<repo>[^/]+)/pull/(?P<num>\d+)\s*$"""
)



def parse_pr_numbers_from_changes(content: str,
                                  expected_owner: str,
                                  expected_repo: str) -> Set[int]:
    """Extract PR numbers that exactly match the documented link format."""
    found: Set[int] = set()
    for line in content.splitlines():
        m = _LINE_RE.match(line.rstrip())
        if m and m.group("owner") == expected_owner and m.group("repo") == expected_repo:
            found.add(int(m.group("num")))
    return found


def get_pr_title(owner: str,
                 repo: str,
                 pr_number: int,
                 token: str | None = None) -> str:
    """Retrieve the PR title (used as a brief description)."""
    url = f"{GITHUB_API}/repos/{owner}/{repo}/pulls/{pr_number}"
    data = _github_get(url, token=token).json()
    return data.get("title", f"PR #{pr_number}")


# ----------------------------------------------------------------------
# Main driver
# ----------------------------------------------------------------------
def main() -> None:
    p = argparse.ArgumentParser(
        description="List closed PRs of a GitHub repo that are NOT mentioned in its doc/changes.rst.",
        epilog="""Without a token, GitHub API rate limits mean you can only query a few URLs.
For the --token option, generate a classic token at https://github.com/settings/tokens with
no additional scope options selected.""",
    )

    p.add_argument("repo_url", help="HTTPS URL of the repository, e.g. https://github.com/desihub/desispec")
    p.add_argument("--token", help="GitHub personal access token (optional).")
    p.add_argument("--after", type=int, default=None,
                   help="Only show PRs with number greater than this value.")
    p.add_argument("--verbose", action="store_true",
                   help="Output reStructuredText entries ready for changes.rst.")
    p.add_argument("-o", "--output", type=Path, default=None,
                   help="Write result to this file; otherwise print to stdout.")
    p.add_argument("--debug", action="store_true",
                   help="Start IPython prompt at end instead of exiting.")
    args = p.parse_args()

    # ------------------------------------------------------------------
    # Resolve owner/repo
    # ------------------------------------------------------------------
    try:
        owner, repo = parse_repo_url(args.repo_url)
    except ValueError as e:
        p.error(str(e))

    # ------------------------------------------------------------------
    # Parse changes.rst
    # ------------------------------------------------------------------
    changes_text = fetch_changes_rst(owner, repo, token=args.token)
    file_prs = parse_pr_numbers_from_changes(changes_text, owner, repo)
    print(f"Found {len(file_prs)} PR references in doc/changes.rst", file=sys.stderr)

    # ------------------------------------------------------------------
    # Get all merged PR numbers from GitHub
    # ------------------------------------------------------------------
    merged_prs = get_merged_prs(owner, repo, token=args.token)      # {num: datetime}
    print(f"Retrieved {len(merged_prs)} merged PRs from GitHub", file=sys.stderr)

    # ------------------------------------------------------------------
    # Compute missing PRs and apply optional ``--after`` filter
    # ------------------------------------------------------------------
    missing_prs = {num: dt for num, dt in merged_prs.items() if num not in file_prs}
    if args.after is not None:
        missing_prs = {num: dt for num, dt in missing_prs.items() if num > args.after}
    print(f"{len(missing_prs)} merged PRs are NOT mentioned in changes.rst after filtering.",
          file=sys.stderr)

    # ------------------------------------------------------------------
    # Load tags (chronological) and group PRs by first tag after merge
    # ------------------------------------------------------------------
    tags = get_tags_with_dates(owner, repo, token=args.token)
    tag_datetimes = dict(tags)  # list[(tag,date)] -> dict[tag]=date
    grouped = group_prs_by_next_tag(missing_prs, tags)

    # ------------------------------------------------------------------
    # Produce output
    # ------------------------------------------------------------------
    out_lines: list[str] = []
    if args.verbose:
        # Verbose mode prints a ready-to-paste reST block.
        for tag, pr_nums in grouped.items():
            # Tag header; use Pacific Time not UTC
            if tag != 'NO_TAG':
                tagdatetime_pacific = tag_datetimes[tag].astimezone(ZoneInfo("America/Los_Angeles"))
                tagdate = tagdatetime_pacific.strftime('%Y-%m-%d')  # YEAR-MM-DD
            else:
                tagdate = 'unreleased'

            line = f"{tag} ({tagdate})"
            out_lines.append(f"\n{line}\n")
            out_lines.append("-"*len(line) + "\n")

            # Descriptions
            out_lines.append("\n")
            for num in sorted(pr_nums):
                title = get_pr_title(owner, repo, num, token=args.token)
                out_lines.append(f"* {title} (PR `#{num}`_).\n")

            # PR link footnotes
            out_lines.append("\n")
            for num in sorted(pr_nums):
                out_lines.append(f".. _`#{num}`: https://github.com/{owner}/{repo}/pull/{num}\n")

            out_lines.append("\n")   # blank line before reference block

    else:
        # Plain list - grouped but still one PR per line, prefixed by tag
        for tag, pr_nums in grouped.items():
            for num in sorted(pr_nums):
                out_lines.append(f"{tag}\t{num}\n")   # tab-separated "tag   PR"

    # Write / print
    if args.output:
        args.output.write_text("".join(out_lines), encoding="utf-8")
        print(f"Wrote output to {args.output}", file=sys.stderr)
    else:
        sys.stdout.writelines(out_lines)

    # debug with IPython
    if args.debug:
        import IPython
        IPython.embed()


if __name__ == "__main__":
    main()
